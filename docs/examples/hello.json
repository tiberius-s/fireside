{
  "fireside-version": "0.1.0",
  "title": "Hello, Fireside",
  "author": "Jane Developer",
  "date": "2026-04-18",
  "description": "Canonical example demonstrating core protocol features.",
  "defaults": {
    "view-mode": "default",
    "transition": "none"
  },
  "nodes": [
    {
      "id": "intro",
      "traversal": "features",
      "content": [
        {
          "kind": "container",
          "layout": "center",
          "children": [
            { "kind": "heading", "level": 1, "text": "Hello, Fireside" },
            { "kind": "text", "body": "A portable format for graph-structured presentations." }
          ]
        }
      ]
    },
    {
      "id": "features",
      "traversal": "choose",
      "content": [
        { "kind": "heading", "level": 2, "text": "Core Features" },
        {
          "kind": "list",
          "items": [
            "Graph-native traversal with explicit edges",
            "Branching with decision points",
            "7 content block types",
            "Two-tier validation (schema + semantic)"
          ]
        },
        { "kind": "divider" },
        { "kind": "text", "body": "Every edge is explicit. No implicit sequential fallback." }
      ]
    },
    {
      "id": "choose",
      "traversal": {
        "branch-point": {
          "prompt": "What would you like to explore?",
          "options": [
            { "label": "Code demo", "key": "a", "target": "code-demo" },
            { "label": "Layout demo", "key": "b", "target": "layout-demo" },
            { "label": "Finish", "key": "c", "target": "thanks" }
          ]
        }
      },
      "content": [
        { "kind": "heading", "level": 2, "text": "Pick a Path" },
        { "kind": "text", "body": "Branching is a first-class protocol concept." }
      ]
    },
    {
      "id": "code-demo",
      "view-mode": "fullscreen",
      "traversal": "thanks",
      "content": [
        { "kind": "heading", "level": 2, "text": "Code Block" },
        {
          "kind": "code",
          "language": "rust",
          "source": "fn main() {\n    let graph = Graph::load(\"hello.json\")?;\n    let engine = Engine::new(graph);\n    engine.present()\n}",
          "highlight-lines": [2, 3],
          "show-line-numbers": true
        }
      ],
      "speaker-notes": "Demonstrate fullscreen view mode with code."
    },
    {
      "id": "layout-demo",
      "traversal": "thanks",
      "content": [
        { "kind": "heading", "level": 2, "text": "Container Layouts" },
        {
          "kind": "container",
          "layout": "columns",
          "children": [
            {
              "kind": "text",
              "body": "**Left column** — containers with `layout: \"columns\"` arrange children side by side."
            },
            {
              "kind": "text",
              "body": "**Right column** — replaces node-level split layouts with an explicit, composable pattern."
            }
          ]
        },
        { "kind": "divider" },
        {
          "kind": "container",
          "layout": "center",
          "children": [
            { "kind": "text", "body": "Centering is a container concern, not a view mode." }
          ]
        }
      ]
    },
    {
      "id": "thanks",
      "transition": "fade",
      "content": [
        {
          "kind": "container",
          "layout": "center",
          "children": [
            { "kind": "heading", "level": 1, "text": "Thanks!" },
            { "kind": "text", "body": "Four operations. Seven blocks. Explicit edges." }
          ]
        }
      ]
    }
  ]
}
